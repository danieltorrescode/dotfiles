# No template variables specified


/usr/bin/zathura {
  include <abstractions/X>
  include <abstractions/base>
  include <abstractions/lxc/container-base>

  /usr/bin/zathura ix,

  deny network,

  deny /run/user/*/gnupg/** rw,
  deny /run/user/*/ssh/** rw,
}
